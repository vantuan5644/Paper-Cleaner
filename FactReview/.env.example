# Copy this file to .env, then fill in MINERU_API_TOKEN.
#
#   cp .env.example .env
#
# Routine users only need this file plus CLI flags.

# 1) Main LLM backend
# Default uses your local Codex login instead of an OpenAI Platform API key.
# Run `codex login` once before using the pipeline.
MODEL_PROVIDER=openai-codex
OPENAI_CODEX_MODEL=gpt-5.5
# Codex backend endpoint. The default points at the ChatGPT-backed Codex
# service used by `codex login`; override only if you have a different
# Codex-compatible endpoint.
OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
# Disable the openai-agents SDK tracing exporter (which would otherwise try to
# POST traces to a tracing endpoint). Leave as-is unless you actively want to
# collect agent traces.
OPENAI_AGENTS_DISABLE_TRACING=1

# 2) PDF parsing
# Required. MinerU's cloud API is free to start with generous quota and avoids
# local CUDA/GPU/MinerU model setup.
MINERU_API_TOKEN=
# Override only if you point at a different MinerU-compatible API endpoint.
MINERU_BASE_URL=https://mineru.net/api/v4

# Local MinerU CLI fallback (used by the execution stage's prepare node when
# the parse-stage snapshot is unavailable). Leave unset for the cloud API
# default; only set these if you have the local `mineru` CLI installed.
# MINERU_LOCAL_BACKEND=pipeline
# MINERU_LOCAL_DEVICE=cpu
# MINERU_LOCAL_SOURCE=

# 3) Teaser figure
# Gemini is optional. Without a key, FactReview saves the exact prompt to disk,
# copies it to your clipboard when possible, and tells you where to paste it.
# If you fill GEMINI_API_KEY, FactReview automatically uses it to generate the image.
GEMINI_API_KEY=

# Force prompt-only output even when GEMINI_API_KEY is set. Equivalent to
# passing --teaser-mode prompt on the CLI.
# TEASER_USE_GEMINI=false
# 4) Objective related-work retrieval (Semantic Scholar)
# Used by the report's "Technical Positioning" section for objective retrieval.
# Strongly recommended: set an API key to avoid rate limits (HTTP 429).
# If this key is empty and retrieval fails, the report may include:
# "Objective retrieval unavailable".
SEMANTIC_SCHOLAR_ENABLED=true
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
# 5) OpenAlex (optional, extra reference cross-check backend)
# Free API key at https://openalex.org/settings/api. Leave OPENALEX_API_KEY
# empty to skip OpenAlex entirely; when set, RefCopilot queries OpenAlex in
# parallel with arXiv / Semantic Scholar / OpenReview / Crossref for stronger
# cross-validation, especially on published journal articles and books.
OPENALEX_API_KEY=
OPENALEX_BASE_URL=https://api.openalex.org
# 5b) Crossref (always on, no API key required)
# Crossref is the official DOI registration agency and the authority for
# published venue/DOI metadata. It is always queried. Setting CROSSREF_MAILTO
# to a contact email routes requests to Crossref's faster "polite pool".
CROSSREF_MAILTO=
CROSSREF_BASE_URL=https://api.crossref.org
# 6) Reference checking
# Disabled by default. Validates bibliography entries with RefChecker and
# appends warnings to the final review. Requires the refcheck submodule
# (`git submodule update --init --recursive`) and `pip install -e ".[refcheck]"`.
# Equivalent to passing --enable-refcheck on the CLI.
# FACTREVIEW_ENABLE_REFCHECK=false
# Optional: also enable a refcheck sweep inside the execution stage's
# refcheck node (separate from the global gate above).
# FACTREVIEW_EXECUTION_ENABLE_REFCHECK=false